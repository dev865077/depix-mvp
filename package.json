{
  "name": "depix-mvp",
  "version": "1.0.0",
  "description": "MVP base do bot DePix rodando em Cloudflare Workers com Hono.",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-vitest-sequential.mjs",
    "obsidian:export": "node scripts/exportar-repositorio-para-obsidian-md.js",
    "cf:types": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:query:local": "wrangler d1 execute DB --local",
    "telegram:preflight": "TMPDIR=/tmp TEMP=/tmp TMP=/tmp tsx scripts/telegram-real-flow-preflight.ts",
    "telegram:real-run": "TMPDIR=/tmp TEMP=/tmp TMP=/tmp tsx scripts/telegram-real-flow-runner.ts",
    "deploy:test": "wrangler deploy --env test",
    "deploy:production": "wrangler deploy --env production"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@grammyjs/parse-mode": "^2.3.0",
    "bech32": "2.0.0",
    "blech32": "1.1.2",
    "grammy": "^1.42.0",
    "hono": "4.12.14",
    "lossless-json": "^4.3.0",
    "xstate": "^5.30.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.14.6",
    "@types/node": "^24.5.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "4.1.4",
    "wrangler": "4.82.2"
  }
}
