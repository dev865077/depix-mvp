{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "lib": ["ES2023"],
    "types": ["node"]
  },
  "include": [
    "src/**/*.js",
    "src/**/*.ts",
    "worker-configuration.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
